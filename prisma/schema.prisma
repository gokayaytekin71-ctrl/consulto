generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Gundem {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String
  createdAt DateTime @default(now())
  content   String

  @@map("gundem")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  /// JSON array storing chat objects for each user
  chats              Json              @default("[]")
  accounts           Account[]
  favoriteKararlar   FavoriteKarar[]
  favoriteMakaleler  FavoriteMakale[]
  favoriteMevzuatlar FavoriteMevzuat[]
  folders            Folder[]
  hearings           Hearing[]
  notes              Note[]
  sessions           Session[]
  Subscription       Subscription[]
  tasks              Task[]
  UsageWeek          UsageWeek[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Karar {
  id            String                   @id @default(cuid())
  fileName      String                   @unique
  content       String
  type          String?
  code          String?
  aiSummary     String?
  createdAt     DateTime                 @default(now())
  contentLength Int?
  keywords      String?
  /// PostgreSQL tsvector column used for full‑text search.
  /// Prisma Client does not support the `tsvector` type.
  /// We intentionally do NOT add `@ignore` here because this model defines GIN indexes
  /// that reference this field. Marking it `@ignore` would invalidate those index definitions
  /// and may cause future migrations to try dropping them.
  tsv_main      Unsupported("tsvector")?
  /// PostgreSQL tsvector column used for full‑text search.
  /// Prisma Client does not support the `tsvector` type.
  /// We intentionally do NOT add `@ignore` here because this model defines GIN indexes
  /// that reference this field (tsv_extra). Marking it `@ignore` would invalidate those index definitions
  /// and may cause future migrations to try dropping them.
  tsv_extra     Unsupported("tsvector")?
  favoriteUsers FavoriteKarar[]

  @@index([contentLength])
  @@index([keywords])
  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "Karar_createdAt_id_desc_idx")
  @@index([tsv_extra], map: "idx_karar_tsv_extra", type: Gin)
  @@index([code(ops: raw("gin_trgm_ops"))], map: "karar_code_trgm", type: Gin)
  @@index([keywords(ops: raw("gin_trgm_ops"))], map: "karar_keywords_trgm", type: Gin)
  @@index([type(ops: raw("gin_trgm_ops"))], map: "karar_type_trgm", type: Gin)
  @@index([tsv_extra], map: "karartsv_extra_gin", type: Gin)
  @@index([tsv_main], map: "karartsv_main_gin", type: Gin)
}

model FavoriteMevzuat {
  id         String   @id @default(cuid())
  userId     String
  mevzuatKey String
  maddeNo    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mevzuatKey, maddeNo])
}

model Mevzuat {
  id           String         @id
  key          String         @unique
  name         String
  content      String
  createdAt    DateTime       @default(now())
  slug         String         @unique
  shortName    String?
  year         Int?
  articleCount Int?
  updatedAt    DateTime       @default(now()) @updatedAt
  maddeler     MevzuatMadde[]
}

model MevzuatMadde {
  id             String   @id @default(cuid())
  mevzuatId      String
  maddeNo        String
  maddeNoOrder   Int?
  maddeBaslik    String?
  maddeUstBaslik String?
  kisim          String?
  bolum          String?
  ayrim          String?
  maddeMetin     String
  orderIndex     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  mevzuat        Mevzuat  @relation(fields: [mevzuatId], references: [id], onDelete: Cascade)

  @@unique([mevzuatId, maddeNo])
  @@index([mevzuatId, orderIndex])
  @@index([mevzuatId, maddeNoOrder])
}

model FavoriteKarar {
  id        String   @id @default(cuid())
  userId    String
  kararId   String
  createdAt DateTime @default(now())
  karar     Karar    @relation(fields: [kararId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kararId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime @default(now())
  folderId  String?
  updatedAt DateTime @default(now()) @updatedAt
  title     String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folderId])
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Hearing {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Makale {
  id            String           @id @default(cuid())
  baslik        String
  doi           String           @unique
  createdAt     DateTime         @default(now())
  favoriteUsers FavoriteMakale[]
}

model Draft {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  dava_turu    String?
  olay_ozet    String?
  talep        String?
  dilekce_md   String
  kaynaklar    Json?
  girdi_ozeti  Json?
  dayanaklar   Json?
  dilekce_json Json?
}

model FavoriteMakale {
  id        String   @id @default(cuid())
  userId    String
  makaleId  String
  createdAt DateTime @default(now())
  makale    Makale   @relation(fields: [makaleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, makaleId])
}

model ibbgk {
  id          BigInt   @id @default(autoincrement())
  karar_code  String   @unique(map: "ibbgk_karar_code_uk")
  birlesme_no String?  @db.VarChar(50)
  icerik      String?
  ozet        String?
  etiketler   Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  content     String?
  pdf_url     String?

  @@index([created_at])
  @@index([karar_code], map: "ibbgk_karar_id_idx")
}

model Subscription {
  id               String             @id
  userId           String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime           @db.Timestamptz(6)
  paytrMerchantOid String?
  createdAt        DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @db.Timestamptz(6)
  SubscriptionPlan SubscriptionPlan   @relation(fields: [planId], references: [id], onUpdate: NoAction, map: "Subscription_plan_fkey")
  User             User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Subscription_user_fkey")

  @@index([userId, status], map: "Subscription_user_status_idx")
}

model SubscriptionPlan {
  id              String         @id
  code            String         @unique
  name            String
  priceMonthly    Int
  analysisPerWeek Int            @default(7)
  dilekcePerWeek  Int            @default(2)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @db.Timestamptz(6)
  Subscription    Subscription[]
}

model UsageWeek {
  id           String @id
  userId       String
  periodKey    String
  analysisUsed Int    @default(0)
  dilekceUsed  Int    @default(0)
  User         User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "UsageWeek_user_fkey")

  @@unique([userId, periodKey], map: "UsageWeek_user_period_key_unique")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}
