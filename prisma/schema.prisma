generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Gundem {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String
  createdAt DateTime @default(now())
  content   String

  @@map("gundem")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  favoriteKararlar   FavoriteKarar[]
  favoriteMakaleler  FavoriteMakale[]
  favoriteMevzuatlar FavoriteMevzuat[]
  folders            Folder[]
  hearings           Hearing[]
  notes              Note[]
  sessions           Session[]

  /// JSON array storing chat objects for each user
  chats        Json     @default("[]")

  tasks              Task[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Mevzuat {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  content   String
  createdAt DateTime @default(now())
}

model Karar {
  id            String          @id @default(cuid())
  fileName      String          @unique
  content       String
  type          String?
  code          String?
  aiSummary     String?
  createdAt     DateTime        @default(now())
  contentLength Int?
  keywords      String?
  favoriteUsers FavoriteKarar[]

  @@index([contentLength])
  @@index([keywords])
}

model FavoriteMevzuat {
  id         String   @id @default(cuid())
  userId     String
  mevzuatKey String
  maddeNo    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mevzuatKey, maddeNo])
}

model FavoriteKarar {
  id        String   @id @default(cuid())
  userId    String
  kararId   String
  createdAt DateTime @default(now())
  karar     Karar    @relation(fields: [kararId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kararId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime @default(now())
  folderId  String?
  updatedAt DateTime @default(now()) @updatedAt
  title     String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folderId])
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Hearing {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Makale {
  id            String           @id @default(cuid())
  baslik        String
  doi           String   @unique
  createdAt     DateTime         @default(now())
  favoriteUsers FavoriteMakale[]
}

model FavoriteMakale {
  id        String   @id @default(cuid())
  userId    String
  makaleId  String
  createdAt DateTime @default(now())
  makale    Makale   @relation(fields: [makaleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, makaleId])
}
